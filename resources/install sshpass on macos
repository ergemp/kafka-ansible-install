
-- ref: https://www.cyberciti.biz/faq/how-to-install-sshpass-on-macos-os-x/

curl -L -O "https://onboardcloud.dl.sourceforge.net/project/sshpass/sshpass/1.10/sshpass-1.10.tar.gz"

tar -zxvf sshpass-1.10.tar.gz

cd sshpass-1.10

./configure
sudo make install

-- ref: https://docs.ansible.com/projects/ansible/latest/reference_appendices/config.html
-- then for disable key-checking
ansible-config init --disabled > ansible.cfg

-- alter the config file
vi ansible.cfg
host_key_checking = False